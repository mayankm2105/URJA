# --- Claude (optional) ---
# Without a key the asset-health agent falls back to a deterministic template
# brief, so the whole API runs with zero external dependencies.
ANTHROPIC_API_KEY=

# Models — default to Opus 4.8; switch BRIEFING_MODEL to claude-haiku-4-5
# to cut cost when briefing the whole fleet at once.
BRIEFING_MODEL=claude-opus-4-8

# --- CORS (your Next.js dev origin) ---
CORS_ORIGINS=http://localhost:3000
