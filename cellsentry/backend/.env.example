# --- Graph backend ---
# auto  = use Neo4j if NEO4J_URI is set, otherwise fall back to in-memory
# neo4j = force Neo4j (fails if not configured)
# memory= force in-memory (no database needed)
GRAPH_BACKEND=auto

# --- Neo4j Aura ---
# Create a free instance: https://neo4j.com/cloud/aura-free/
# After creating, download the credentials file and paste the values below.
NEO4J_URI=
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=

# --- Claude (needed from Week 2 for extraction & briefing agents) ---
ANTHROPIC_API_KEY=

# --- CORS (your Next.js dev origin) ---
CORS_ORIGINS=http://localhost:3000
